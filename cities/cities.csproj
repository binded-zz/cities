<?xml version="1.0" encoding="utf-8"?>
<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Library</OutputType>
    <TargetFramework>net6.0</TargetFramework>
    <RootNamespace>CitiesSkylines2Mod</RootNamespace>
    <AssemblyName>CitiesSkylines2Mod</AssemblyName>
    <Version>1.0.0.0</Version>
    <LangVersion>latest</LangVersion>
  </PropertyGroup>

  <ItemGroup>
    <Reference Include="Colossal.Logging">
      <HintPath>..\Refs\Colossal.Logging.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <Reference Include="Game">
      <HintPath>..\Refs\Game.dll</HintPath>
      <Private>false</Private>
    </Reference>
  </ItemGroup>

  <Target Name="BuildCitiesUI" AfterTargets="Build">
    <Exec Command="npm run build" WorkingDirectory=".." ContinueOnError="true" />
  </Target>

</Project>